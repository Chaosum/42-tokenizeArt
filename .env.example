# -------------------------------------------------------
# CLÉ PRIVÉE DE TON WALLET METAMASK
# Pour l'obtenir : MetaMask > 3 points > Détails du compte > Exporter la clé privée
# ATTENTION : donne accès total à ton wallet. N'utilise JAMAIS un wallet avec de vraies crypto.
# -------------------------------------------------------
PRIVATE_KEY=0xTON_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clé privée secondaire (optionnel) utilisée par `deployment/demo.js` pour tests
PRIVATE_KEY_2=0xTON_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -------------------------------------------------------
# RPC URL pour Sepolia (ex: Alchemy / Infura / QuickNode / Thirdweb)
SEPOLIA_RPC_URL=https://11155111.rpc.thirdweb.com/

# Adresse du contrat déployé (TokenizeArt42) - renseigner après deploy
CONTRACT_ADDRESS=0xfDa69C63D6ecAD394656702bF6b0dCad07C970a9

# Clé API Etherscan (pour la vérification du contrat)
# Obtenir sur https://etherscan.io/myapikey
ETHERSCAN_API_KEY=TON_ETHERSCAN_API_KEY

# -------------------------------------------------------
# Paramètres de mint (utilisés par mint/upload-and-mint.js)
# -------------------------------------------------------

# URL de l'image NFT (raw GitHub, IPFS ou HTTPS public)
# https://ipfsviewer.eth.link/?hash=ipfs%3A%2F%2Fbafybeidit2ud3timi5zzlpyomwofvfnstlr3ujbl2euwa4my3xgewi2fky
NFT_IMAGE_URI=ipfs://bafybeidit2ud3timi5zzlpyomwofvfnstlr3ujbl2euwa4my3xgewi2fky

# Titre du NFT
MINT_TITLE=42fusArt

# Nom de l'artiste
MINT_ARTIST=mservage

# Adresse de destination du mint
MINT_TO=0x28fe19527be172AB91641408adD376F35E85fFF5

