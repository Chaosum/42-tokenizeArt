# Variables d'environnement — TokenizeArt42
# ⚠️  COPIE CE FICHIER EN ".env" ET REMPLIS LES VALEURS
# ⚠️  NE COMMIT JAMAIS TON FICHIER .env SUR GIT !
# Le fichier .gitignore doit contenir ".env"

# -------------------------------------------------------
# CLÉ PRIVÉE DE TON WALLET METAMASK
# Pour l'obtenir : MetaMask > 3 points > Détails du compte > Exporter la clé privée
# ATTENTION : donne accès total à ton wallet. N'utilise JAMAIS un wallet avec de vraies crypto.
# -------------------------------------------------------
PRIVATE_KEY=0xTON_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -------------------------------------------------------
# -------------------------------------------------------
# RPC URL pour Sepolia (ex: Alchemy / Infura / QuickNode)
# Exemple: https://eth-sepolia.g.alchemy.com/v2/TON_KEY
SEPOLIA_RPC_URL=https://

# Clé privée secondaire (optionnel) utilisée par `deployment/demo.js` pour tests
PRIVATE_KEY_2=0xTON_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# API KEY Etherscan (optionnel — pour vérifier le contrat sur Etherscan)
# Création gratuite sur : https://etherscan.io/apis
ETHERSCAN_API_KEY=TON_API_KEY_ETHERSCAN

# API KEY BSCSCAN (optionnel — si tu veux aussi déployer/verifier sur BSC Testnet)
# Création gratuite sur : https://bscscan.com/register
BSCSCAN_API_KEY=TON_API_KEY_BSCSCAN
